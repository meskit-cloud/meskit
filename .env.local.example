# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LLM Provider: "google" (default) | "openai" | "anthropic"
LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash  # Optional: override default model per provider

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (uncomment to use with LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key

# Anthropic (uncomment to use with LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key
